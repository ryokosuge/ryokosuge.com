{
  "name": "ryokosuge-theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i assets/css/main.css -o ../../assets/css/main.css",
    "build:prod": "tailwindcss -i assets/css/main.css -o ../../assets/css/main.css --minify",
    "watch": "tailwindcss -i assets/css/main.css -o ../../assets/css/main.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.1"
  }
}
